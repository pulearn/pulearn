"""Template benchmark entry for a new PU learner."""

import warnings

from <benchmark_module> import run_benchmark_case

from pulearn import <EstimatorClass>
from pulearn import detect_degenerate_predictor


def build_<algorithm_key>():
    return <EstimatorClass>(<constructor arguments>)


def register_<algorithm_key>_benchmark():
    result = run_benchmark_case(
        name="<algorithm_key>",
        estimator_builder=build_<algorithm_key>,
        metrics=("pu_f1", "pu_roc_auc"),
    )
    # Degenerate-predictor sanity check.
    # If the benchmark harness stores PU labels and predicted scores on the
    # result object, check them for common failure modes and warn loudly.
    if hasattr(result, "y_pu") and hasattr(result, "y_score"):
        det = detect_degenerate_predictor(result.y_pu, result.y_score)
        if det.is_degenerate:
            warnings.warn(
                f"[{result.name}] Degenerate predictor detected: "
                f"flags={det.flags}  stats={det.stats}",
                stacklevel=2,
            )
    return result
